    "competitions": {
      ".indexOn": ["tarih", "yil", "baslangicTarihi", "bitisTarihi", "il", "isim"],

      "$competitionId": {
        ".indexOn": ["tarih", "isim", "il"],

        "kategoriler": {
          "$categoryId": {
            ".indexOn": ["name"]
          }
        },

        "sporcular": {
          "$categoryId": {
            ".indexOn": ["soyadAd", "lisansNo", "okul", "il", "yarismaTuru"],

            "$athleteId": {
              ".indexOn": ["lisansNo", "soyadAd", "tckn", "okul", "il", "yarismaTuru", "sirasi", "cikisSirasi"]
            }
          }
        },

        "puanlar": {
          "$categoryId": {
            "$apparatusId": {
              "$athleteId": {
                ".indexOn": ["toplam", "finalScore", "sonuc", "durum"]
              }
            }
          }
        },

        "siralama": {
          "$categoryId": {
            "$rotationId": {
              "$athleteId": {
                ".indexOn": ["sirasi"]
              }
            }
          }
        },

        "hakemler": {
          ".indexOn": ["name"],
          "$categoryId": {
            "$apparatusId": {}
          }
        },

        "teamDeductions": {
          ".indexOn": ["teamName", "team"]
