      "$year": {
        ".indexOn": ["isActive"],

        "metadata": {},

        "$categoryId": {
          ".indexOn": ["isActive"],

          "metadata": {},

          "$apparatusId": {
            ".indexOn": ["isActive", "hakemSayisi"]
          }
        }
      }
