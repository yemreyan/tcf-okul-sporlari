    "globalSporcular": {
      ".indexOn": ["lisansNo", "tckn", "soyadAd", "cinsiyet", "kategori"],

      "$athleteKey": {
        ".indexOn": ["lisansNo", "tckn", "soyadAd"]
      }
    },

    "applications": {
      ".indexOn": ["competitionId", "status", "durum", "createdAt", "olusturmaTarihi", "okul", "il"],

      "$applicationId": {
        ".indexOn": ["competitionId", "status", "durum", "kategoriId", "categoryId"],
        ".validate": "newData.hasChildren(['competitionId', 'okul', 'il', 'ilce', 'sporcular', 'durum', 'kategoriId', 'brans']) && newData.child('okul').val().length <= 200 && newData.child('il').val().length <= 100 && newData.child('ilce').val().length <= 100 && newData.child('brans').val().length <= 50 && (newData.child('durum').val() === 'bekliyor' || newData.child('durum').val() === 'onaylandi' || newData.child('durum').val() === 'reddedildi')",

        "durum": {
          ".validate": "newData.val() === 'bekliyor' || newData.val() === 'onaylandi' || newData.val() === 'reddedildi'"
        },

        "okul": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 200"
        },

        "il": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 100"
        },

        "ilce": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 100"
        }
      }
    },

    "kullanicilar": {
      "$userId": {
        ".indexOn": ["email", "role", "rolAdi", "kullaniciAdi", "aktif", "il"]
      }
