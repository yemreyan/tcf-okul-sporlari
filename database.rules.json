{
  "rules": {
    ".read": true,
    ".write": true,

    "competitions": {
      ".indexOn": ["tarih", "yil", "baslangicTarihi", "il"],

      "$competitionId": {
        ".indexOn": ["tarih"],

        "kategoriler": {
          "$categoryId": {
            ".indexOn": ["name"]
          }
        },

        "sporcular": {
          "$categoryId": {
            "$athleteId": {
              ".indexOn": ["lisansNo", "soyadAd", "tckn", "okul"]
            }
          }
        },

        "puanlar": {
          "$categoryId": {
            "$apparatusId": {
              "$athleteId": {
                ".indexOn": ["toplam", "durum"]
              }
            }
          }
        },

        "hakemler": {
          ".indexOn": ["name"]
        },

        "teamDeductions": {
          ".indexOn": ["teamName"]
        },

        "katilimcilar": {},
        "aktifSporcu": {},
        "flashTrigger": {},
        "program": {},
        "siralama": {},
        "onayli_okullar": {}
      }
    },

    "globalSporcular": {
      ".indexOn": ["lisansNo", "tckn", "soyadAd", "cinsiyet"],

      "$athleteKey": {
        ".indexOn": ["lisansNo"]
      }
    },

    "applications": {
      ".indexOn": ["competitionId", "status", "createdAt", "olusturmaTarihi"],

      "$applicationId": {
        ".indexOn": ["competitionId", "status"]
      }
    },

    "kullanicilar": {
      "$userId": {
        ".indexOn": ["email", "role", "rolAdi"]
      }
    },

    "broadcasts": {
      ".indexOn": ["competitionId", "createdAt"],

      "$broadcastId": {}
    },

    "referees": {
      "$refereeId": {
        ".indexOn": ["adSoyad", "brans", "il"]
      }
    },

    "defaultCriteria": {
      "$criteriaType": {
        ".indexOn": ["name"]
      }
    },

    "criteria": {},

    "reports": {},

    "logs": {
      ".indexOn": ["timestamp", "type", "competitionId", "user"]
    }
  }
}
